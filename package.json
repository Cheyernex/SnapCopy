{
  "name": "snap-copy",
  "private": true,
  "author": "CMT DEV SOLUTIONS",
  "version": "1.1.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on -t 20000 http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.6",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "vite": "^5.4.11",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.snapcopy.app",
    "productName": "SnapCopy",
    "publish": [
      {
        "provider": "github",
        "owner": "Cheyernex",
        "repo": "SnapCopy"
      }
    ],
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "artifactName": "SnapCopy-Setup.${ext}",
      "uninstallDisplayName": "SnapCopy",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SnapCopy",
      "runAfterFinish": true
    }
  }
}